{# <p>Any custom bits only for the home page can be added... </p> #}
<div class="rounded-lg grid  grid-cols-1 md:grid-cols-2 lg:grid-cols-3 shadow-lg shadow-slate-400">
  <div class= "font-Test2 p-4 text-4xl">Activity</div>

    <div class="col-span-2">
      <div class="grid grid-flow-row auto-rows-4 md:auto-rows-4 ">
      {% set projectsCount = collections.projects | length %}
      {% set latestProjectsCount = projectsCount | min(numberOfLatestProjectsToShow) %} 
      {% set projectlist = collections.projects | head(-1 * numberOfLatestProjectsToShow) %}
      {% set projectlistCounter = projectsCount %}
      {% for project in projectlist | reverse %}
      <div class="border border-indigo-600 font-Test2 hover:text-black  bg-opacity-25">
        <a href="{{ project.url }}">
        <div class="m-1">
        <time datetime="{{ project.date | htmlDateString }}" class="text-zinc-500">{{ project.date | readableDate }}</time>
        <h1 class="hover:bg-zinc-300">{{ project.data.title }}</h1>
        </div>
        </a>
      </div>
      {% endfor %}
      {% set moreProjects = projectsCount - numberOfLatestProjectsToShow %}
    {% if moreProjects > 0 %}
    <div class="font-Test2 hover:text-black border border-indigo-600 text-right"><h2 class="pr-2 hover:bg-zinc-300"> <a href="/projects/">VIEW PAST </a></h2></div>

    {% endif %}

      </div>
    </div>
    


</div>

<h1 class="rounded-md font-Test2 m-4 pt-5">Project Categories</h1>
<div class="text-center px-8 py-4 mt-4 border-indigo-600 border border-dotted">
    {% for tag in collections.all | getAllTags | filterTagList %}
        {% set tagUrl %}/tags/{{ tag | slugify }}/{% endset %}
        <a href="{{ tagUrl }}" class="hover:text-black hover:bg-zinc-300">{{ tag }}</a>{%- if not loop.last %} &nbsp; |  &nbsp; {% endif %}
    {% endfor %}
</div>

        


